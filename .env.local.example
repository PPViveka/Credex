# -----------------------------------------------------------------------------
# CREDEX AI SPEND AUDIT ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env.local and configure your credentials.
# The application automatically runs in graceful mock fallback mode if these are missing.
# -----------------------------------------------------------------------------

# Supabase (Database Backend lead storage & audit records)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Anthropic Claude API (Fractional CFO executive summary generation)
# Optional: Fallback will generate high-fidelity deterministic text if missing
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend Transactional Email Service (Lead notification confirmation triggers)
# Optional: Fallback will print full HTML email bodies in console logs if missing
RESEND_API_KEY=re_your_resend_api_key_here
